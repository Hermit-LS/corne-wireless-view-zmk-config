#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    behaviors {
        spaceshift: spaceshift {
            compatible = "zmk,behavior-hold-tap";
            label = "SPACESHIFT";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            hold-trigger-key-positions = <38>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BKSP |
            // | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
            // | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
            //                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |

            display-name = "Base";
            bindings = <
&kp ESCAPE        &kp Q  &kp W  &kp F  &kp P    &kp B                           &kp J                 &kp L          &kp U      &kp Y    &kp SEMICOLON  &kp LEFT_ALT
&kp TAB           &kp A  &kp R  &kp S  &kp T    &kp G                           &kp M                 &kp N          &kp E      &kp I    &kp O          &kp SINGLE_QUOTE
&kp LEFT_COMMAND  &kp Z  &kp X  &kp C  &kp D    &kp V                           &kp K                 &kp H          &kp COMMA  &kp DOT  &kp FSLH       &kp LEFT_CONTROL
                                &mo 1  &kp DEL  &spaceshift LEFT_SHIFT SPACE    &mt LEFT_SHIFT ENTER  &kp BACKSPACE  &mo 2
            >;
        };

        lower_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BKSP |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
            // | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            display-name = "Lower";
            bindings = <
&trans  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5    &kp F6        &kp F7  &kp F8  &kp F9  &kp F10  &trans
&trans  &kp N1  &kp N2  &kp N3  &kp N4  &kp N5    &kp NUMBER_6  &kp N7  &kp N8  &kp N9  &kp N0   &trans
&trans  &none   &none   &none   &none   &none     &none         &none   &trans  &trans  &trans   &trans
                        &trans  &trans  &trans    &trans        &trans  &trans
            >;
        };

        raise_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  (  |  )  | BKSP |
            // | CTRL |     |     |     |     |     |   |  -  |  =  |  [  |  ]  |  \  |  `   |
            // | SHFT |     |     |     |     |     |   |  _  |  +  |  {  |  }  | "|" |  ~   |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            display-name = "Raise";
            bindings = <
&trans  &none      &kp TILDE      &kp GRAVE  &kp LEFT_BRACE        &kp RIGHT_BRACE          &none   &none           &none      &none       &none     &none
&trans  &kp CARET  &kp BACKSLASH  &kp PIPE   &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS    &none   &kp MINUS       &kp EQUAL  &kp EXCL    &kp AT    &none
&trans  &kp HASH   &kp PERCENT    &kp STAR   &kp LEFT_BRACKET      &kp RIGHT_BRACKET        &none   &kp UNDERSCORE  &kp PLUS   &kp DOLLAR  &kp AMPS  &none
                                  &trans     &trans                &trans                   &trans  &trans          &trans
            >;
        };

        Functions {
            display-name = "Functions";
            bindings = <
&bt BT_CLR  &none  &none       &none          &none      &none        &none  &none     &none     &none   &none      &none
&bt BT_NXT  &none  &kp DELETE  &kp BACKSPACE  &kp SPACE  &kp ENTER    &none  &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &none
&bt BT_PRV  &none  &none       &none          &none      &none        &none  &none     &none     &none   &none      &none
                               &none          &none      &none        &none  &none     &none
            >;
        };
    };

    conditional_layers {
        compatible = "zmk,conditional-layers";

        Func {
            if-layers = <1 2>;
            then-layer = <3>;
        };
    };
};
